-- ========== TARGET NOCLIP ==========
local function EnableTargetNoclip(player)
    if not player or not player.Character then 
        infoLabel.Text = "❌ Jogador sem personagem!"
        return 
    end
    
    if targetNoclipConnection then
        targetNoclipConnection:Disconnect()
        targetNoclipConnection = nil
    end
    
    targetNoclipConnection = RunService.Stepped:Connect(function()
        if player and player.Character and player.Character.Parent then
            for _, part in pairs(player.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end)
    
    Settings.TargetNoclipEnabled = true
    buttons.TARGETNOCLIP.BackgroundColor3 = LightPurple
    infoLabel.Text = "✅ " .. player.Name .. " agora atravessa paredes!"
    task.wait(1.5)
    infoLabel.Text = "✅ Selecione um jogador na lista | Clique em um personagem para trocar"
end

local function DisableTargetNoclip()
    if targetNoclipConnection then
        targetNoclipConnection:Disconnect()
        targetNoclipConnection = nil
    end
    
    if Settings.SelectedPlayer and Settings.SelectedPlayer.Character then
        for _, part in pairs(Settings.SelectedPlayer.Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
    end
    
    Settings.TargetNoclipEnabled = false
    buttons.TARGETNOCLIP.BackgroundColor3 = DarkPurple
    infoLabel.Text = "❌ NoClip do alvo: DESATIVADO"
    task.wait(1)
    infoLabel.Text = "✅ Selecione um jogador na lista | Clique em um personagem para trocar"
end

-- ========== TELEPORT ==========
local function TeleportToPlayer(player)
    if not player or not player.Character then 
        infoLabel.Text = "❌ Jogador inválido!"
        return false 
    end
    
    local targetRoot = player.Character:FindFirstChild("HumanoidRootPart")
    local myCharacter = LocalPlayer.Character
    
    if not targetRoot or not myCharacter then 
        infoLabel.Text = "❌ Personagem não encontrado!"
        return false 
    end
    
    local myRoot = myCharacter:FindFirstChild("HumanoidRootPart")
    if not myRoot then return false end
    
    buttons.TELEPORT.BackgroundColor3 = LightPurple
    myRoot.CFrame = targetRoot.CFrame + Vector3.new(0, 3, 0)
    
    infoLabel.Text = "✅ Teleportado para " .. player.Name
    task.wait(0.5)
    buttons.TELEPORT.BackgroundColor3 = PurpleColor
    task.wait(0.5)
    infoLabel.Text = "✅ Selecione um jogador na lista | Clique em um personagem para trocar"
    
    return true
end

-- ========== VISION ==========
local function EnableVision()
    if currentEffect then
        DisableVision()
    end
    
    local bloom = Instance.new("BloomEffect")
    bloom.Name = "AghataBloom"
    bloom.Intensity = 0.15
    bloom.Size = 8
    bloom.Threshold = 0.9
    bloom.Parent = Lighting
    
    local colorCorrection = Instance.new("ColorCorrectionEffect")
    colorCorrection.Name = "AghataColor"
    colorCorrection.TintColor = LightPurple
    colorCorrection.Contrast = 0.03
    colorCorrection.Brightness = 0.01
    colorCorrection.Saturation = 0.05
    colorCorrection.Parent = Lighting
    
    currentEffect = {bloom, colorCorrection}
end

local function DisableVision()
    if currentEffect then
        for _, effect in pairs(currentEffect) do
            if effect and effect.Parent then
                effect:Destroy()
            end
        end
        currentEffect = nil
    end
    
    if currentConnection then
        currentConnection:Disconnect()
        currentConnection = nil
    end
    
    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            Camera.CameraSubject = humanoid
        end
    end
end

local function ViewPlayer(player)
    DisableVision()
    
    if not player or not player.Character then
        infoLabel.Text = "❌ Jogador inválido!"
        return
    end
    
    local humanoid = player.Character:FindFirstChild("Humanoid")
    
    if humanoid and humanoid.Health > 0 then
        EnableVision()
        Camera.CameraSubject = humanoid
        
        infoLabel.Text = "👁️ Visualizando: " .. player.Name
        
        currentConnection = RunService.RenderStepped:Connect(function()
            if not player.Character or not player.Character.Parent then
                DisableVision()
                infoLabel.Text = "✅ Visualização encerrada"
            end
            
            local currentHumanoid = player.Character:FindFirstChild("Humanoid")
            if not currentHumanoid or currentHumanoid.Health <= 0 then
                DisableVision()
                infoLabel.Text = "✅ Visualização encerrada"
            end
        end)
    else
        infoLabel.Text = "❌ Jogador inválido ou morto!"
    end
end


-- ========== FUNÇÃO PARA DETECTAR PERSONAGENS DO JOGO ==========
local function DetectAvailableCharacters()
    characterList = {}
    
    -- Limpar lista antiga
    for _, child in pairs(charScroll:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    -- MÉTODO 1: Procurar em ReplicatedStorage
    local storageChars = ReplicatedStorage:FindFirstChild("Characters") or 
                         ReplicatedStorage:FindFirstChild("Character") or
                         ReplicatedStorage:FindFirstChild("Chars")
    
    if storageChars then
        for _, child in pairs(storageChars:GetChildren()) do
            if child:IsA("Folder") or child:IsA("Model") or (child:IsA("ModuleScript") and not table.find(characterList, child.Name)) then
                table.insert(characterList, child.Name)
            end
        end
    end
    
    -- MÉTODO 2: Procurar em StarterPlayer
    local starterPlayer = game:GetService("StarterPlayer")
    local starterChars = starterPlayer:FindFirstChild("StarterCharacter") or
                         starterPlayer:FindFirstChild("StarterCharacters")
    
    if starterChars then
        if starterChars:IsA("Model") then
            table.insert(characterList, starterChars.Name)
        elseif starterChars:IsA("Folder") then
            for _, child in pairs(starterChars:GetChildren()) do
                if child:IsA("Model") then
                    table.insert(characterList, child.Name)
                end
            end
        end
    end
    
    -- MÉTODO 3: Procurar em Workspace (personagens carregados)
    for _, child in pairs(Workspace:GetChildren()) do
        if child:IsA("Model") and child:FindFirstChild("Humanoid") and child ~= LocalPlayer.Character then
            local charName = child.Name
            if not table.find(characterList, charName) then
                table.insert(characterList, charName)
            end
        end
    end
    
    -- MÉTODO 4: Lista manual de personagens comuns (fallback)
    if #characterList == 0 then
        characterList = {
            "Default", "Character", "Player", "Robloxian",
            "Noob", "Guest", "Developer", "Admin"
        }
    end
    
    -- Remover duplicatas
    local uniqueList = {}
    for _, name in pairs(characterList) do
        if not table.find(uniqueList, name) then
            table.insert(uniqueList, name)
        end
    end
    characterList = uniqueList
    
    -- Criar botões na UI
    for _, charName in pairs(characterList) do
        local charBtn = Instance.new("TextButton")
        charBtn.Size = UDim2.new(1,0,0,35)
        charBtn.BackgroundColor3 = Color3.fromRGB(35,35,35)
        charBtn.Text = "👤 " .. charName
        charBtn.TextColor3 = Color3.new(1,1,1)
        charBtn.TextSize = 11
        charBtn.Font = Enum.Font.Gotham
        charBtn.TextXAlignment = Enum.TextXAlignment.Left
        charBtn.Parent = charScroll
        
        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0,5)
        btnCorner.Parent = charBtn
        
        -- Ao clicar, trocar personagem
        charBtn.MouseButton1Click:Connect(function()
            Settings.SelectedCharacter = charName
            ChangeCharacter(charName)
        end)
    end
    
    charLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        charScroll.CanvasSize = UDim2.new(0,0,0,charLayout.AbsoluteContentSize.Y + 10)
    end)
    
    infoLabel.Text = "🎮 " .. #characterList .. " personagens encontrados!"
    task.wait(1.5)
    infoLabel.Text = "✅ Selecione um jogador na lista | Clique em um personagem para trocar"
end

-- ========== FUNÇÃO PARA TROCAR PERSONAGEM ==========
local function ChangeCharacter(characterName)
    if not characterName then 
        infoLabel.Text = "❌ Nenhum personagem selecionado!"
        return 
    end
    
    buttons.SWAPCHAR.BackgroundColor3 = LightPurple
    
    -- Método 1: Usar RemoteEvent (mais comum)
    local remoteEvent = ReplicatedStorage:FindFirstChild("CharacterSwap") or
                        ReplicatedStorage:FindFirstChild("ChangeCharacter") or
                        ReplicatedStorage:FindFirstChild("SetCharacter") or
                        ReplicatedStorage:FindFirstChild("SelectCharacter")
    
    if remoteEvent and remoteEvent:IsA("RemoteEvent") then
        remoteEvent:FireServer(characterName)
        infoLabel.Text = "🔄 Trocando para: " .. characterName
    else
        -- Método 2: Usar BindableFunction
        local bindFunc = ReplicatedStorage:FindFirstChild("CharacterService") or
                         ReplicatedStorage:FindFirstChild("CharacterHandler")
        
        if bindFunc and bindFunc:IsA("BindableFunction") then
            bindFunc:Invoke(characterName)
            infoLabel.Text = "🔄 Trocando para: " .. characterName
        else
            -- Método 3: Forçar respawn com novo personagem
            local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
            if playerGui then
                local characterButton = playerGui:FindFirstChild(characterName) or
                                       playerGui:FindFirstChild("Character_" .. characterName)
                if characterButton and characterButton:IsA("TextButton") then
                    characterButton:Click()
                    infoLabel.Text = "🔄 Trocando para: " .. characterName
                else
                    -- Método 4: Simular clique em GUI (último recurso)
                    local success = false
                    local function searchAndClick(parent)
                        for _, child in pairs(parent:GetChildren()) do
                            if child:IsA("TextButton") and string.find(child.Name or "", characterName) then
                                child:Click()
                                success = true
                                return
                            end
                            if not success then
                                searchAndClick(child)
                            end
                        end
                    end
                    
                    local guiRoot = game:GetService("CoreGui")
                    searchAndClick(guiRoot)
                    
                    if success then
                        infoLabel.Text = "🔄 Trocando para: " .. characterName
                    else
                        infoLabel.Text = "⚠️ Não foi possível trocar para " .. characterName .. " automaticamente"
                        buttons.SWAPCHAR.BackgroundColor3 = RedColor
                        task.wait(1.5)
                        buttons.SWAPCHAR.BackgroundColor3 = GreenColor
                        return
                    end
                end
            end
        end
    end
    
    task.wait(1)
    buttons.SWAPCHAR.BackgroundColor3 = GreenColor
    task.wait(0.5)
    infoLabel.Text = "✅ Selecione um jogador na lista | Clique em um personagem para trocar"
end

-- ========== HITBOX FUNCIONAL ==========
local function CreateFunctionalHitboxForPlayer(player)
    if not player or player == LocalPlayer then return end
    if not player.Character then return end
    
    local character = player.Character
    local humanoid = character:FindFirstChild("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("UpperTorso")
    
    if rootPart and humanoid and humanoid.Health > 0 then
        if hitboxConnections[player] then
            return
        end
        
        local hitbox = Instance.new("Part")
        hitbox.Size = Vector3.new(Settings.HitboxSize, Settings.HitboxSize, Settings.HitboxSize)
        hitbox.Transparency = 0.35
        hitbox.Color = PurpleColor
        hitbox.Material = Enum.Material.Neon
        hitbox.Anchored = false
        hitbox.CanCollide = false
        hitbox.CanQuery = true
        hitbox.CanTouch = true
        
        local weld = Instance.new("WeldConstraint")
        weld.Part0 = hitbox
        weld.Part1 = rootPart
        weld.Parent = hitbox
        
        hitbox.Parent = workspace
        
        -- Script de dano com mudança de cor
        local damageScript = Instance.new("Script")
        damageScript.Source = [[
            local hitboxPart = script.Parent
            local targetCharacter = ]] .. tostring(character) .. [[
            local targetHumanoid = targetCharacter and targetCharacter:FindFirstChild("Humanoid")
            
            local playersAttacked = {}
            local damageTimer = nil
            
            local function SetRedColor()
                hitboxPart.Color = Color3.fromRGB(255, 0, 0)
                hitboxPart.Transparency = 0.3
            end
            
            local function SetPurpleColor()
                hitboxPart.Color = Color3.fromRGB(128, 0, 255)
                hitboxPart.Transparency = 0.35
            end
            
            hitboxPart.Touched:Connect(function(hit)
                local playerChar = hit and hit.Parent
                if not playerChar then return end
                
                local humanoid = playerChar:FindFirstChild("Humanoid")
                if not humanoid then return end
                
                local player = game:GetService("Players"):GetPlayerFromCharacter(playerChar)
                if not player then return end
                
                if playerChar == targetCharacter then return end
                
                local lastAttack = playersAttacked[player]
                if lastAttack and tick() - lastAttack < 0.3 then
                    return
                end
                
                playersAttacked[player] = tick()
                SetRedColor()
                
                if targetHumanoid and targetHumanoid.Health > 0 then
                    local hitboxSize = hitboxPart.Size.X
                    local damage = math.min(25, math.floor(hitboxSize * 1.5))
                    targetHumanoid.Health = math.max(0, targetHumanoid.Health - damage)
                end
                
                if damageTimer then
                    game:GetService("RunService").Stepped:Wait()
                end
                
                damageTimer = game:GetService("RunService").Stepped:Connect(function()
                    wait(0.2)
                    SetPurpleColor()
                    if damageTimer then
                        damageTimer:Disconnect()
                        damageTimer = nil
                    end
                end)
            end)
        ]]
        damageScript.Disabled = false
        damageScript.Parent = hitbox
        
        hitboxConnections[player] = {
            hitbox = hitbox,
            weld = weld,
            script = damageScript
        }
        
        local updateColor = function()
            if hitbox and hitbox.Parent then
                if humanoid.Health <= 0 then
                    hitbox.Color = Color3.fromRGB(60,60,60)
                    hitbox.Transparency = 0.7
                else
                    hitbox.Color = PurpleColor
                    hitbox.Transparency = 0.35
                end
            end
        end
        
        updateColor()
        humanoid:GetPropertyChangedSignal("Health"):Connect(updateColor)
        
        humanoid.Died:Connect(function()
            if hitboxConnections[player] then
                if hitboxConnections[player].hitbox then
                    hitboxConnections[player].hitbox:Destroy()
                end
                hitboxConnections[player] = nil
            end
        end)
    end
end

local function RemoveAllHitboxes()
    for player, data in pairs(hitboxConnections) do
        if data.hitbox then
            data.hitbox:Destroy()
        end
    end
    hitboxConnections = {}
end

local function EnableGlobalHitbox()
    RemoveAllHitboxes()
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            task.wait(0.1)
            CreateFunctionalHitboxForPlayer(player)
        end
    end
    
    local function onPlayerAdded(player)
        if player ~= LocalPlayer then
            task.wait(0.5)
            if Settings.HitboxEnabled then
                CreateFunctionalHitboxForPlayer(player)
            end
        end
    end
    
    local function onCharacterAdded(character, player)
        task.wait(0.5)
        if Settings.HitboxEnabled then
            CreateFunctionalHitboxForPlayer(player)
        end
    end
    
    hitboxConnections["_playerAdded"] = Players.PlayerAdded:Connect(onPlayerAdded)
    hitboxConnections["_playerRemoving"] = Players.PlayerRemoving:Connect(function(player)
        if hitboxConnections[player] then
            if hitboxConnections[player].hitbox then
                hitboxConnections[player].hitbox:Destroy()
            end
            hitboxConnections[player] = nil
        end
    end)
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local connection = player.CharacterAdded:Connect(function(character)
                onCharacterAdded(character, player)
            end)
            hitboxConnections["_char_" .. player.Name] = connection
        end
    end
end

local function DisableGlobalHitbox()
    RemoveAllHitboxes()
    
    if hitboxConnections["_playerAdded"] then
        hitboxConnections["_playerAdded"]:Disconnect()
    end
    if hitboxConnections["_playerRemoving"] then
        hitboxConnections["_playerRemoving"]:Disconnect()
    end
    
    for key, conn in pairs(hitboxConnections) do
        if type(key) == "string" and string.sub(key, 1, 6) == "_char_" then
            if conn then conn:Disconnect() end
        end
    end
    
    hitboxConnections = {}
end

local function ToggleHitbox()
    Settings.HitboxEnabled = not Settings.HitboxEnabled
    
    if Settings.HitboxEnabled then
        EnableGlobalHitbox()
        buttons.HITBOX.BackgroundColor3 = LightPurple
        sizeInput.Visible = true
        infoLabel.Text = "✅ Hitbox GLOBAL: ATIVADO (Roxo🔮 | Fica Vermelho🔴 ao dar dano)"
    else
        DisableGlobalHitbox()
        buttons.HITBOX.BackgroundColor3 = DarkPurple
        sizeInput.Visible = false
        infoLabel.Text = "❌ Hitbox GLOBAL: DESATIVADO"
    end
    task.wait(1.5)
    infoLabel.Text = "✅ Selecione um jogador na lista | Clique em um personagem para trocar"
end

-- ========== BRING (TRAZER) ==========
local function BringPlayer(player)
    if not player or not player.Character then 
        infoLabel.Text = "❌ Jogador inválido!"
        return false 
    end
    
    local targetRoot = player.Character:FindFirstChild("HumanoidRootPart")
    local myCharacter = LocalPlayer.Character
    
    if not targetRoot or not myCharacter then 
        infoLabel.Text = "❌ Personagem não encontrado!"
        return false 
    end
    
    local myRoot = myCharacter:FindFirstChild("HumanoidRootPart")
    if not myRoot then return false end
    
    buttons.BRING.BackgroundColor3 = LightPurple
    
    local bringPosition = myRoot.CFrame + (myRoot.CFrame.LookVector * 2)
    
    local originalCollision = {}
    for _, part in pairs(player.Character:GetDescendants()) do
        if part:IsA("BasePart") then
            originalCollision[part] = part.CanCollide
            part.CanCollide = false
        end
    end
    
    targetRoot.CFrame = bringPosition
    
    infoLabel.Text = "✨ " .. player.Name .. " foi trazido até você!"
    task.wait(0.5)
    buttons.BRING.BackgroundColor3 = PurpleColor
    
    task.wait(1)
    for part, collidable in pairs(originalCollision) do
        if part and part.Parent then
            part.CanCollide = collidable
        end
    end
    
    task.wait(0.5)
    infoLabel.Text = "✅ Selecione um jogador na lista | Clique em um personagem para trocar"
    
    return true
end

-- ========== NOCLIP PRÓPRIO ==========
local function EnableNoclip()
    if noclipConnection then
        noclipConnection:Disconnect()
    end
    
    noclipConnection = RunService.Stepped:Connect(function()
        local character = LocalPlayer.Character
        if character then
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                for _, part in pairs(character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
